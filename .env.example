# Copy to .env and fill in real values before running docker compose.
# Section headers marked [EXTERNAL SETUP REQUIRED] need accounts/config outside this
# repo — see README.md "Prerequisites" for the full checklist.

NODE_ENV=production
PORT=4000

# Public HTTPS URL Caddy serves the app on. In dev this can stay http://localhost:4000.
PUBLIC_BASE_URL=https://your-domain.example.com
# Bare domain Caddy requests a TLS cert for (production only).
PUBLIC_DOMAIN=your-domain.example.com

# --- Data stores (docker-compose supplies these automatically in-cluster; only
# needed here if you run the app processes directly on the host) ---
DATABASE_URL=postgres://whatsapp_dashboard:whatsapp_dashboard@localhost:5432/whatsapp_dashboard
REDIS_URL=redis://localhost:6379
POSTGRES_PASSWORD=whatsapp_dashboard

# --- Auth ---
# openssl rand -hex 32
JWT_SECRET=replace-with-64-hex-characters-________________________________
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Encrypts per-number WhatsApp credentials at rest (AES-256-GCM).
# openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=replace-with-64-hex-characters-________________________________

# --- [EXTERNAL SETUP REQUIRED] Meta WhatsApp Business Platform ---
# From your Meta App's Basic Settings.
META_APP_SECRET=
# Any string you choose; enter the same value in Meta's webhook config screen.
META_WEBHOOK_VERIFY_TOKEN=
META_GRAPH_API_VERSION=v21.0

# --- Media storage (inbound message attachments) ---
MEDIA_STORAGE_DRIVER=local
MEDIA_STORAGE_LOCAL_PATH=./data/media

# --- Seed script (first run only, apps/server: npm run db:seed) ---
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-immediately
